{
  "name": "hevy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20.0.0" },
  "bin": { "hevy": "./dist/bin.js" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/bin.ts",
    "hevy": "tsx src/bin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "LIVE=1 vitest run --testNamePattern @live",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "commander": "14.0.3",
    "zod": "4.4.3",
    "cli-table3": "0.6.5"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "eslint": "10.4.0",
    "msw": "2.14.6",
    "prettier": "3.8.3",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
